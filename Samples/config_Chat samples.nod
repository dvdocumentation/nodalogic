        {
            "name": "MyTaskSample",
            "section": "Примеры чатов",
            "section_code": "chats_samples_documents",
            "has_storage": false,
            "display_name": "MyTaskSample",
            "record_view": "{title}",
            "cover_image": "[\r\n  [  {\"type\":\"Text\",\"value\":\"@title\",\"bold\":true} ],\r\n  [  {\"type\":\"Text\",\"value\":\"@address\"} ],\r\n[  {\"type\":\"Text\",\"value\":\"\"} ],\r\n  [{\"type\":\"Button\",\"id\":\"btn_accept\",\"caption\":\"Accept\",\"visible\":\"@accept_visibility\"},{\"type\":\"Button\",\"id\":\"btn_done\",\"caption\":\"Done\",\"background\":\"#378228\",\"visible\":\"@done_visibility\"},{\"type\":\"Button\",\"id\":\"btn_decline\",\"caption\":\"Decline\",\"background\":\"#F54927\",\"visible\":\"@decline_visibility\"}],\r\n[{\"type\":\"Text\",\"value\":\"@status\",\"radius\":10,\"visible\":\"@status_visibility\",\"width\":-2,\"w\":0,\"stroke\":1}]\r\n]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "[\r\n  [ {\"type\":\"Input\",\"caption\":\"Title\",\"id\":\"title\",\"value\":\"@title\"} ],\r\n  [ {\"type\":\"Input\",\"caption\":\"Address\",\"id\":\"address\",\"value\":\"@address\"} ],\r\n  [{\"type\":\"Input\",\"caption\":\"Description\",\"id\":\"body\",\"input_type\":\"muliline\",\"value\":\"@body\"}]\r\n]",
            "init_screen_layout_web": "",
            "plug_in": "[{\"type\":\"ToolbarButton\",\"id\":\"btn_reset\",\"caption\":\"Сбросить задачу\"}]",
            "plug_in_web": "",
            "commands": "",
            "use_standard_commands": true,
            "svg_commands": "",
            "migration_register_command": false,
            "migration_register_on_save": false,
            "migration_default_room_uid": "",
            "migration_default_room_alias": "",
            "link_share_mode": "",
            "indexes": [],
            "class_type": "data_node",
            "hidden": false,
            "methods": [],
            "events": [
                {
                    "event": "onAccept",
                    "listener": "",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "if not (\"started\" in _data){\n      message(\"стартуем задачу\");\n  _data.accept_visibility = 1;\n  _data.done_visibility = 1;\n  _data.decline_visibility = 1;\n  _data.status_visibility = -1;\n}else{\n  if _data.done=true or _data.decline=true {\n    message(\"завершаем задачу\");\n     _data.accept_visibility = -1;\n     _data.done_visibility = -1;\n     _data.decline_visibility = -1;\n     _data.status_visibility = 1;\n\n  }\n}"
                        }
                    ]
                },
                {
                    "event": "onInput",
                    "listener": "btn_accept",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "message(\"*Accepted\");\n_data.accept_visibility = -1;\n_data.started = true;\n_data.status=\"Принято\";\nSave();\nRefreshTab();\n"
                        }
                    ]
                },
                {
                    "event": "onInput",
                    "listener": "btn_done",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "_data.done=true;\n_data.status=\"Завершена\";\nSave();\nRefreshTab();"
                        }
                    ]
                },
                {
                    "event": "onInput",
                    "listener": "btn_decline",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "_data.decline=true;\n_data.status = \"Отклонена\";\nSave();\nRefreshTab();"
                        }
                    ]
                },
                {
                    "event": "onInput",
                    "listener": "btn_reset",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "_data.remove(\"started\");\n_data.remove(\"done\");\n_data.remove(\"decline\");\nSave();\nRefreshTab();"
                        }
                    ]
                }
            ]
        },
