            "name": "InstallationOrder",
            "section": "Примеры чатов",
            "section_code": "chats_samples_documents",
            "has_storage": false,
            "display_name": "InstallationOrder",
            "record_view": "#{number} , {date} , {client}",
            "cover_image": "[\r\n  [ {\"type\":\"Text\",\"value\":\"Номер\"}, {\"type\":\"Text\",\"value\":\"@num\",\"bold\":true}, {\"type\":\"Text\",\"value\":\"Date\"}, {\"type\":\"Text\",\"value\":\"@date\",\"bold\":true} ],\r\n  [ {\"type\":\"Text\",\"value\":\"Клиент\"}, {\"type\":\"NodeLink\",\"value\":\"@client\",\"bold\":true} ],\r\n  [ {\"type\":\"Text\",\"value\":\"Статус\"}, {\"type\":\"Text\",\"value\":\"@status_view\",\"bold\":true} ]\r\n]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "[\r\n  [ {\"type\":\"Input\",\"caption\":\"Номер заявки\",\"id\":\"num\",\"value\":\"@num\",\"input_type\":\"number\"}, {\"type\":\"Input\",\"caption\":\"Дата выезда\",\"id\":\"date\",\"value\":\"@date\",\"input_type\":\"date\"} ],\r\n  [ {\"type\":\"NodeInput\",\"caption\":\"Клиент\",\"id\":\"client\",\"dataset\":\"Client\",\"value\":\"@client\"} ],\r\n  [ {\"type\":\"Input\",\"caption\":\"Адрес\",\"id\":\"address\",\"value\":\"@address\", \"input_type\":\"multiline\"} ],\r\n  [ {\"type\":\"Spinner\",\"caption\":\"Статус\",\"id\":\"status\",\"value\":\"@status\",\"dataset\":[{\"_view\":\"Принят в работу\",\"_id\":\"accepted\"},{\"_view\":\"Выезд\",\"_id\":\"visit_in_progress\"},{\"_view\":\"Работа начата\",\"_id\":\"inprogres\"},{\"_view\":\"Завершен\",\"_id\":\"done\"}]} ],\r\n  [ {\"type\":\"Tabs\",\"value\":[\r\n    {\"type\":\"Tab\",\"id\":\"tab_1\",\"caption\":\"Показания счетчиков\",\"layout\":[[{\"type\":\"Table\",\"id\":\"measurements\",\"virtual_node\":{\"layout\":[[{\"type\":\"Input\",\"caption\":\"Показатель\",\"id\":\"id\",\"value\":\"@id\"},{\"type\":\"Input\",\"caption\":\"Значение\",\"id\":\"value\",\"value\":\"@value\",\"input_type\":\"number\"}]],\"cover\":[[{\"type\":\"Text\",\"value\":\"@id\",\"bold\":true},{\"type\":\"Text\",\"value\":\"@value\",\"bold\":true}]]}}]]},\r\n    {\"type\":\"Tab\",\"id\":\"tab_2\",\"caption\":\"Материалы\",\"layout\":[[{\"type\":\"Table\",\"id\":\"tab2\",\"virtual_node\":{\"layout\":[[{\"type\":\"DatasetField\",\"caption\":\"Материал\",\"id\":\"materis\",\"dataset\":\"rawmaterials\",\"value\":\"@materis\"},{\"type\":\"Input\",\"caption\":\"Количество\",\"id\":\"qty\",\"value\":\"@qty\",\"input_type\":\"number\"}]],\"cover\":[[{\"type\":\"DatasetLink\",\"value\":\"@materis\",\"bold\":true},{\"type\":\"Text\",\"value\":\"@qty\",\"bold\":true}]]}}]]},\r\n    {\"type\":\"Tab\",\"id\":\"tab_1\",\"caption\":\"Чек-лист\",\"layout\":[[{\"type\":\"VerticalLayout\",\"width\":-1,\"value\":[{\"type\":\"CheckBox\",\"caption\":\"Доставка\",\"id\":\"check_delivery\",\"value\":\"@check_delivery\"},{\"type\":\"CheckBox\",\"caption\":\"Проверка комплектации\",\"id\":\"check_complete\",\"value\":\"@check_complete\"},{\"type\":\"CheckBox\",\"caption\":\"Монтаж\",\"id\":\"check_installation\",\"value\":\"@check_installation\"},{\"type\":\"CheckBox\",\"caption\":\"Подключение\",\"id\":\"check_plugin\",\"value\":\"@check_plugin\"}]}]]}\r\n   ]} ]\r\n]",
            "init_screen_layout_web": "",
            "plug_in": "",
            "plug_in_web": "",
            "commands": "",
            "use_standard_commands": true,
            "svg_commands": "",
            "migration_register_command": false,
            "migration_register_on_save": false,
            "migration_default_room_uid": "",
