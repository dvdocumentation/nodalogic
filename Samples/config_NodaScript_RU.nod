            "events": [
                {
                    "event": "onInput",
                    "listener": "my_question_positive",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "Сообщить(\"To be\");\nbeep()"
                        }
                    ]
                },
                {
                    "event": "onInput",
                    "listener": "btn_get_rate",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "ответ = HTTPRequest(\"GET\", \"https://www.cbr-xml-daily.ru/daily_json.js\", Неопределено, Неопределено);\nЕсли ответ.status = 200 Тогда\n    данные = ответ.json;\n    курс = данные.Valute.USD.Value;\n    Сообщить(\"Курс доллара: \" + Строка(курс));\n    _data.usd= курс;\n    Сохранить()\nИначе\n    Сообщить(\"Ошибка HTTP: \" + Строка(ответ.status))\nКонецЕсли"
                        }
                    ]
                },
                {
                    "event": "onInputWeb",
                    "listener": "my_question_positive",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "Сообщить(\"To be\")\n"
                        }
                    ]
                },
                {
                    "event": "onInputWeb",
                    "listener": "btn_get_rate",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "ответ = HTTPRequest(\"GET\", \"https://www.cbr-xml-daily.ru/daily_json.js\", Неопределено, Неопределено);\nЕсли ответ.status = 200 Тогда\n    данные = ответ.json;\n    курс = данные.Valute.USD.Value;\n    Сообщить(\"Курс доллара: \" + Строка(курс));\n    _data.usd= курс;\n    Сохранить()\nИначе\n    Сообщить(\"Ошибка HTTP: \" + Строка(ответ.status))\nКонецЕсли"
                        }
                    ]
                },
                {
