    "classes": [
        {
            "name": "MyOrder",
            "section": "NodaScript",
            "section_code": "noda_script_samples",
            "has_storage": true,
            "display_name": "MyOrder",
            "cover_image": "[\r\n[{\"type\":\"Text\",\"value\":\"Заказ\",\"bold\":true}],\r\n[{\"type\":\"Text\",\"value\":\"Строки заказа Товар-Цена можно забить в веб-версии, а в мобильной версии проставить количество\"}],\r\n[{\"type\":\"Text\",\"value\":\"#возврат ?('lines' in _data,' есть строки ',' нет строк ')\",\"radius\":10,\"background\":\"#701705\",\"width\":-2,\"w\":0,\"text_color\":\"#FFFFFF\"}]\r\n]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "[\r\n[ {\"type\":\"Parameters\",\"w\":1}, {\"type\":\"Table\",\"id\":\"tab1\",\"value\":\"@lines\",\"layout\":[\r\n[{\"type\":\"Text\",\"value\":\"@position\",\"id\":\"position\",\"bold\":true}],\r\n[{\"type\":\"Text\",\"value\":\"Цена\"},{\"type\":\"Text\",\"value\":\"@price\"}],\r\n[{\"type\":\"Button\",\"small\":true,\"gravity\":\"rigth\",\"caption\":\"+\",\"id\":\"btn_plus\",\"onClickParent\":\"line = _data.lines[_data.tab1_input_position]; if not HasProperty(line,'qty') {line.qty=0;};  line.qty = line.qty + 1;refresh();\"},{\"type\":\"Text\",\"value\":\"@qty\",\"id\":\"qty\",\"gravity\":\"center\"},{\"type\":\"Button\",\"small\":true,\"caption\":\"-\",\"id\":\"btn_minus\",\"onClickParent\":\"line = _data.lines[_data.tab1_input_position]; if not HasProperty(line,'qty') {line.qty=0;}; line.qty = line.qty - 1;refresh();\"},{\"type\":\"Text\",\"value\":\"#Если _data.qty!=Неопределено и _data.price!=Неопределено Тогда возврат _data.qty*_data.price  Иначе  возврат  '--' КонецЕсли\",\r\n\"gravity\":\"right\"}]],\"height\":-1} ],\r\n\r\n  [ {\"type\":\"Text\",\"value\":\"Total : \"}, {\"type\":\"Text\",\"value\":\"#sum = 0; if HasProperty(_data,'lines') and _data.lines != null { for i = 0; i < Length(_data.lines); i = i + 1 { line = _data.lines[i]; if HasProperty(line,'qty') and HasProperty(line,'price') and line.qty != null and line.price != null { sum = sum + line.qty * line.price; } } } return sum;\",\"gravity\":\"right\",\"bold\":true} ]\r\n]",
            "init_screen_layout_web": "[\r\n  [ {\"type\":\"Button\",\"id\":\"btn_add_child\",\"caption\":\"Add line\"} ],\r\n  [ {\"type\":\"Parameters\",\"w\":1}, {\"type\":\"Table\",\"id\":\"tab1\",\"value\":\"@lines\",\"layout\":[\r\n[{\"type\":\"Text\",\"value\":\"@position\",\"id\":\"position\",\"bold\":true}],\r\n[{\"type\":\"Text\",\"value\":\"Цена\"},{\"type\":\"Text\",\"value\":\"@price\"}],\r\n[{\"type\":\"Button\",\"small\":true,\"gravity\":\"rigth\",\"caption\":\"+\",\"id\":\"btn_plus\",\"onClickParent\":\"line = _data.lines[_data.tab1_input_position]; if not HasProperty(line,'qty') {line.qty=0;};  line.qty = line.qty + 1;refresh();\"},{\"type\":\"Text\",\"value\":\"@qty\",\"id\":\"qty\",\"gravity\":\"center\"},{\"type\":\"Button\",\"small\":true,\"caption\":\"-\",\"id\":\"btn_minus\",\"onClickParent\":\"line = _data.lines[_data.tab1_input_position]; if not HasProperty(line,'qty') {line.qty=0;}; line.qty = line.qty - 1;refresh();\"},{\"type\":\"Text\",\"value\":\"#Если _data.qty!=Неопределено и _data.price!=Неопределено Тогда возврат _data.qty*_data.price  Иначе  возврат  '--' КонецЕсли\",\r\n\"gravity\":\"right\"}]],\"height\":-1} ],\r\n\r\n  [ {\"type\":\"Text\",\"value\":\"Total : \"}, {\"type\":\"Text\",\"value\":\"#sum = 0; if HasProperty(_data,'lines') and _data.lines != null { for i = 0; i < Length(_data.lines); i = i + 1 { line = _data.lines[i]; if HasProperty(line,'qty') and HasProperty(line,'price') and line.qty != null and line.price != null { sum = sum + line.qty * line.price; } } } return sum;\",\"gravity\":\"right\",\"bold\":true} ]\r\n]",
