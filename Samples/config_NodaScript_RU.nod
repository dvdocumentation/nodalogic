        {
            "name": "LayoutTest",
            "section": "NodaScript",
            "section_code": "noda_script_samples",
            "has_storage": false,
            "display_name": "LayoutTest",
            "cover_image": "[[\"Тесты использования в разметке. Только Android\"]]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "[\r\n  [ {\"type\":\"Button\",\"id\":\"btn_update\",\"caption\":\"Simple button\",\"onClick\":\"message('btn_update')\"} ],\r\n  [ {\"type\":\"Switch\",\"caption\":\"Setting 1\",\"id\":\"sw1\",\"value\":\"@sw1\",\"onChange\":\"message(_data.sw1)\"} ],\r\n  [ {\"type\":\"Table\",\"id\":\"tab4\",\"value\":\"@lines\",\"table\":true,\"table_header\":[\"#|n|1\",\"Position|position|7\",\"Qty|qty|1\"],\"onClick\":\"message(_data.tab4_selected_position)\"} ]\r\n]",
            "init_screen_layout_web": "",
            "plug_in": "",
            "plug_in_web": "",
            "commands": "",
            "use_standard_commands": true,
            "svg_commands": "",
            "migration_register_command": false,
            "migration_register_on_save": false,
            "migration_default_room_uid": "",
            "migration_default_room_alias": "",
            "class_type": "custom_process",
            "hidden": false,
            "methods": [],
            "events": [
                {
                    "event": "onShow",
                    "listener": "",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "lines = Новый Массив;\nДля i=0 по 10 Цикл\n  //вместо этого можно Новый Структура(\"Ключ1\", Значение1, \"Ключ2\", Значение2)... но так удобнее\n  line = {\"n\":i,\"position\":\"Продукция #\"+String(i)};\n  lines.add(line);\nКонецЦикла;\n\n_data.lines = lines\n"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Functions",
            "section": "NodaScript",
            "section_code": "noda_script_samples",
            "has_storage": true,
            "display_name": "Functions",
            "cover_image": "[\r\n[\"Вызов функций из NodaScript\"],\r\n[\"Курс USD|@usd\"]\r\n]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "[\r\n[{\"type\":\"Button\",\"id\":\"btn_dialog\",\"caption\":\"Dialog\"}],\r\n[{\"type\":\"Button\",\"id\":\"btn_get_rate\",\"caption\":\"Курс ЦБ\"}],\r\n[{\"type\":\"Button\",\"id\":\"btn_close\",\"caption\":\"Close\",\"onClick\":\"RefreshTab();CloseNode()\"}],\r\n[{\"type\":\"Button\",\"id\":\"btn_get_date\",\"caption\":\"Current date\"}]\r\n]",
