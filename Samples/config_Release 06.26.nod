        {
            "name": "S3PutGet",
            "section": "Релиз июнь 26",
            "section_code": "june26",
            "has_storage": false,
            "display_name": "S3PutGet",
            "record_view": "",
            "cover_image": "[\r\n[{\"type\":\"Text\",\"value\":\"Методы для работы с s3 хранилищем\",\"bold\":true}],\r\n[\"В этом примере - NodaScript, такие же методы в python:\"],\r\n[\"url = s3put(path)\"],\r\n[\"path=s3get(url)\"]\r\n]",
            "display_image_web": "",
            "display_image_table": "",
            "init_screen_layout": "",
            "init_screen_layout_web": "",
            "data_structure": "",
            "show_tag_cloud": false,
            "mobile_print_enabled": false,
            "plug_in": "[{\"type\":\"PhotoButton\",\"id\":\"photo\"}]",
            "plug_in_web": "",
            "commands": "",
            "use_standard_commands": true,
            "svg_commands": "",
            "migration_register_command": false,
            "migration_register_on_save": false,
            "migration_default_room_uid": "",
            "migration_default_room_alias": "",
            "link_share_mode": "",
            "indexes": [],
            "class_type": "custom_process",
            "projection_type": "",
            "projection_kanban_columns": "",
            "print_template_type": "html_jinja",
            "print_target_classes": [],
            "print_html_template": "",
            "hidden": false,
            "methods": [],
            "events": [
                {
                    "event": "onInput",
                    "listener": "photo",
                    "actions": [
                        {
                            "action": "run",
                            "source": "internal",
                            "server": "",
                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "url = s3put(_data.photo); //синхронная выгрузка в s3, на выходе ссылка\npath = s3get(url); //сохранение с s3, на выходе - путь\nmessage(\"Загрузили в \"+string(url));"
                        }
                    ]
                }
            ]
        },
        {
