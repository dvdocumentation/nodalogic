                            "method": "NodaScript",
                            "postExecuteMethod": "",
                            "methodText": "sku_id = getByIndex(\"Goods\",\"barcode\",_data.barcode); //one value result\nif sku_id!=null {\n message(getData(sku_id).name); //getData return _data of node by _id\n}else{\n  message(\"SKU not found\");\n}"
